{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fortress NestJS API (sole DB owner)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "build": "nest build",
    "clean": "rm -rf dist",
    "dev": "nest start --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fortress/auth-core": "workspace:*",
    "@fortress/crypto": "workspace:*",
    "@fortress/observability": "workspace:*",
    "@fortress/types": "workspace:*",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "ioredis": "5.8.2",
    "nestjs-pino": "4.6.1",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@fortress/config-eslint": "workspace:*",
    "@fortress/config-typescript": "workspace:*",
    "@nestjs/cli": "11.0.21",
    "@nestjs/testing": "11.1.19",
    "@types/express": "5.0.6",
    "@types/pg": "8.20.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.28.0",
    "supertest": "7.2.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.5"
  }
}
