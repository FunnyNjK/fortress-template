# =============================================================================
# Fortress — environment template (safe to commit).
# DO NOT commit a populated `.env`; copy this file and fill secrets locally.
# =============================================================================

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Public browser-facing web app origin (local dev: Next.js default port).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Public API base URL as seen by the browser.
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
# Internal API URL for health checks and server-to-server calls on the host.
API_INTERNAL_URL=http://127.0.0.1:4000

# -----------------------------------------------------------------------------
# Clerk (identity)
# Source: Clerk Dashboard → API Keys / Webhooks
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-with-clerk-publishable-key
CLERK_SECRET_KEY=replace-with-clerk-secret-key
CLERK_WEBHOOK_SECRET=replace-with-clerk-webhook-secret

# -----------------------------------------------------------------------------
# Postmark (email)
# Source: Postmark → Servers → API Tokens; Sender Signatures; Streams; Webhooks
# -----------------------------------------------------------------------------
POSTMARK_API_TOKEN=replace-with-postmark-api-token
POSTMARK_FROM_EMAIL=replace-with-postmark-from-email
POSTMARK_TRANSACTIONAL_STREAM=replace-with-postmark-transactional-stream
POSTMARK_BROADCAST_STREAM=replace-with-postmark-broadcast-stream
POSTMARK_WEBHOOK_SECRET=replace-with-postmark-webhook-secret

# -----------------------------------------------------------------------------
# Stripe (billing)
# Source: Stripe Dashboard → Developers → API keys / Webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# Source: Sentry → Project Settings → Client Keys (DSN); Auth Token for CI uploads
# -----------------------------------------------------------------------------
SENTRY_DSN=replace-with-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=replace-with-next-public-sentry-dsn
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token

# -----------------------------------------------------------------------------
# OTLP / Tempo (observability)
# Source: Grafana Cloud / self-hosted Tempo OTLP HTTP or gRPC endpoint docs
# -----------------------------------------------------------------------------
OTLP_ENDPOINT=http://127.0.0.1:4318
OTLP_HEADERS=replace-with-otlp-headers

# -----------------------------------------------------------------------------
# Database
# Local: Postgres from docker-compose.yml (host port 5432). Credentials must match
# compose when using the bundled Postgres service (see root docker-compose.yml).
# -----------------------------------------------------------------------------
# Must match the user/db embedded in DATABASE_URL below and in docker-compose.yml.
POSTGRES_USER=fortress
POSTGRES_DB=fortress
DATABASE_URL=postgresql://fortress:replace-with-local-postgres-password@127.0.0.1:5432/fortress

# -----------------------------------------------------------------------------
# Redis
# Local: Redis from docker-compose.yml (host port 6379).
# -----------------------------------------------------------------------------
REDIS_URL=redis://:replace-with-local-redis-password@127.0.0.1:6379

# -----------------------------------------------------------------------------
# Unleash (feature flags)
# Local: Unleash UI/API from docker-compose.yml (host port 4242).
# Source (hosted): Unleash → Instance admin → API tokens
# -----------------------------------------------------------------------------
UNLEASH_URL=http://127.0.0.1:4242
UNLEASH_API_TOKEN=replace-with-unleash-api-token
NEXT_PUBLIC_UNLEASH_URL=http://127.0.0.1:4242
NEXT_PUBLIC_UNLEASH_CLIENT_KEY=replace-with-next-public-unleash-client-key

# -----------------------------------------------------------------------------
# Encryption
# 32-byte key, base64-encoded (generated by setup scripts in dev).
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=replace-with-base64-32-byte-encryption-key

# -----------------------------------------------------------------------------
# API — session / audit fingerprinting
# HMAC-SHA256 key for hashing bearer tokens, client IP, and User-Agent (min 32 chars).
# -----------------------------------------------------------------------------
FORTRESS_REQUEST_HMAC_KEY=replace-with-fortress-request-hmac-key-min-32-chars

# Dev-only: JWKS stub + x-debug-user-id (set true only for local API dev; never in production).
ALLOW_DEV_AUTH=false

# -----------------------------------------------------------------------------
# CSP report URI
# Source: App/security tooling endpoint that accepts CSP violation reports
# -----------------------------------------------------------------------------
CSP_REPORT_URI=http://127.0.0.1:4000/replace-with-csp-report-path

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
NODE_ENV=development

# Azure (production / CI federation)
# Source: Azure Portal → Microsoft Entra ID → App registrations / subscriptions / Key Vault / Storage
AZURE_CLIENT_ID=replace-with-azure-client-id
AZURE_TENANT_ID=replace-with-azure-tenant-id
AZURE_SUBSCRIPTION_ID=replace-with-azure-subscription-id
AZURE_KEY_VAULT_URL=https://replace-with-keyvault-name.vault.azure.net/
AZURE_STORAGE_ACCOUNT_NAME=replace-with-azure-storage-account-name
AZURE_STORAGE_CONTAINER_NAME=replace-with-azure-storage-container-name
