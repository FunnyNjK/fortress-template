{
  "name": "@fortress/config-typescript",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript compiler configuration presets for the Fortress monorepo.",
  "license": "UNLICENSED",
  "files": [
    "*.json",
    "README.md",
    "fortress-config-stub.d.ts"
  ],
  "exports": {
    "./base.json": "./base.json",
    "./next.json": "./next.json",
    "./node.json": "./node.json",
    "./library.json": "./library.json"
  },
  "scripts": {
    "typecheck": "tsc --version && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.package-path.json"
  }
}
